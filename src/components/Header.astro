---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { href: '/', label: '首页' },
  { href: '/music/', label: '音乐' },
  { href: '/projects/', label: '项目' },
  { href: '/blog/', label: '博客' },
  { href: '/contact/', label: '联系' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/80 backdrop-blur-md dark:border-slate-800/80 dark:bg-slate-950/80">
  <nav class="container-main flex h-16 items-center justify-between">
    <a href="/" class="text-xl font-bold text-slate-900 no-underline dark:text-white">
      Nathuris
    </a>

    <!-- 桌面导航 -->
    <div class="hidden items-center gap-1 sm:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`rounded-lg px-3 py-2 text-sm font-medium transition-colors no-underline ${
            currentPath === item.href
              ? 'bg-accent-50 text-accent-700 dark:bg-accent-950 dark:text-accent-400'
              : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-white'
          }`}
        >
          {item.label}
        </a>
      ))}
      <div class="ml-2">
        <ThemeToggle />
      </div>
    </div>

    <!-- 移动端菜单按钮 -->
    <div class="flex items-center gap-2 sm:hidden">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        class="rounded-lg p-2 text-slate-600 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800"
        aria-label="打开菜单"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- 移动端菜单 -->
  <div id="mobile-menu" class="hidden border-t border-slate-200 bg-white px-4 py-3 dark:border-slate-800 dark:bg-slate-950 sm:hidden">
    {navItems.map((item) => (
      <a
        href={item.href}
        class={`block rounded-lg px-3 py-2 text-sm font-medium transition-colors no-underline ${
          currentPath === item.href
            ? 'bg-accent-50 text-accent-700 dark:bg-accent-950 dark:text-accent-400'
            : 'text-slate-600 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800'
        }`}
      >
        {item.label}
      </a>
    ))}
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
