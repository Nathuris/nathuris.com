---
export interface Props {
  title: string;
  audioUrl?: string;
  soundcloudUrl?: string;
  coverImage?: string;
}

const { title, audioUrl, soundcloudUrl, coverImage } = Astro.props;
---

<div class="overflow-hidden rounded-xl border border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900">
  <!-- SoundCloud 嵌入 -->
  {soundcloudUrl && (
    <div class="p-4">
      <iframe
        width="100%"
        height="166"
        scrolling="no"
        frameborder="no"
        allow="autoplay"
        src={`https://w.soundcloud.com/player/?url=${encodeURIComponent(soundcloudUrl)}&color=%236366f1&auto_play=false&hide_related=true&show_comments=false&show_user=false&show_reposts=false`}
        class="rounded-lg"
      ></iframe>
    </div>
  )}

  <!-- 直接上传的音频文件 -->
  {!soundcloudUrl && audioUrl && (
    <div class="p-4">
      <!-- 封面图 -->
      {coverImage && (
        <div class="mb-4 aspect-square w-full max-w-[200px] mx-auto overflow-hidden rounded-lg">
          <img src={coverImage} alt={title} class="h-full w-full object-cover" />
        </div>
      )}
      <audio controls class="w-full">
        <source src={audioUrl} type="audio/mpeg" />
        您的浏览器不支持音频播放。
      </audio>
    </div>
  )}
</div>
