---
export interface Props {
  title: string;
  description?: string;
  coverImage?: string;
  linkUrl?: string;
  tags?: string[];
  date?: Date;
  slug: string;
}

const { title, description, coverImage, linkUrl, tags, date, slug } = Astro.props;
---

<article class="card group">
  <a href={`/music/${slug}/`} class="no-underline">
    <!-- 封面图 -->
    {coverImage ? (
      <div class="mb-4 aspect-square overflow-hidden rounded-lg bg-slate-100 dark:bg-slate-800">
        <img src={coverImage} alt={title} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
      </div>
    ) : (
      <div class="mb-4 flex aspect-square items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800">
        <svg class="h-12 w-12 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
        </svg>
      </div>
    )}

    <h3 class="text-lg font-semibold text-slate-900 dark:text-white group-hover:text-accent-600 dark:group-hover:text-accent-400">
      {title}
    </h3>
  </a>

  {description && (
    <p class="mt-2 line-clamp-2 text-sm text-slate-500 dark:text-slate-400">{description}</p>
  )}

  {tags && tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1.5">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  )}
</article>
