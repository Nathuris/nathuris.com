---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const music = await getCollection('music');
  return music.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { title, description, coverImage, audioUrl, soundcloudUrl, tags, date } = item.data;
const { Content } = await render(item);
---

<BaseLayout title={title} description={description}>

  <article class="py-16">
    <div class="container-main">
      <!-- 返回链接 -->
      <a href="/music/" class="mb-8 inline-flex items-center gap-1 text-sm text-slate-500 hover:text-accent-600 dark:text-slate-400 no-underline">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        返回音乐列表
      </a>

      <div class="grid gap-8 lg:grid-cols-3">
        <!-- 左侧：音频播放器 -->
        <div class="lg:col-span-1">
          <div class="sticky top-24">
            <AudioPlayer
              title={title}
              audioUrl={audioUrl}
              soundcloudUrl={soundcloudUrl}
              coverImage={coverImage}
            />
          </div>
        </div>

        <!-- 右侧：详情 -->
        <div class="lg:col-span-2">
          <header class="mb-8">
            <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
            {date && (
              <time class="mt-2 block text-sm text-slate-500 dark:text-slate-400" datetime={date.toISOString()}>
                {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            )}
            {tags && tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-1.5">
                {tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            )}
          </header>

          {description && (
            <p class="mb-8 text-lg leading-relaxed text-slate-600 dark:text-slate-400">{description}</p>
          )}

          <div class="prose prose-slate max-w-none dark:prose-invert">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
