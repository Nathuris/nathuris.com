---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const music = await getCollection('music');
  return music.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { title, description, coverImage, linkUrl, tags, date } = item.data;
const { Content } = await render(item);
---

<BaseLayout title={title} description={description}>

  <article class="py-16">
    <div class="container-main">
      <a href="/music/" class="mb-8 inline-flex items-center gap-1 text-sm text-slate-500 hover:text-accent-600 dark:text-slate-400 no-underline">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        返回音乐列表
      </a>

      <div class="grid gap-8 lg:grid-cols-3">
        <!-- 左侧：封面 + 收听按钮 -->
        <div class="lg:col-span-1">
          <div class="sticky top-24 space-y-4">
            {coverImage ? (
              <img src={coverImage} alt={title} class="w-full rounded-xl shadow-md" />
            ) : (
              <div class="flex aspect-square w-full items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800">
                <svg class="h-16 w-16 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
                </svg>
              </div>
            )}

            {linkUrl && (
              <a href={linkUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary w-full justify-center">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                在网易云音乐收听
              </a>
            )}
          </div>
        </div>

        <!-- 右侧：详情 -->
        <div class="lg:col-span-2">
          <header class="mb-8">
            <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
            {date && (
              <time class="mt-2 block text-sm text-slate-500 dark:text-slate-400" datetime={date.toISOString()}>
                {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            )}
            {tags && tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-1.5">
                {tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            )}
          </header>

          {description && (
            <p class="mb-8 text-lg leading-relaxed text-slate-600 dark:text-slate-400">{description}</p>
          )}

          <div class="prose prose-slate max-w-none dark:prose-invert">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
