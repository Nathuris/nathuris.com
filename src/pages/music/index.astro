---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MusicCard from '../../components/MusicCard.astro';
import { getCollection } from 'astro:content';

const allMusic = await getCollection('music');
const music = allMusic.sort((a, b) => (b.data.date?.getTime() || 0) - (a.data.date?.getTime() || 0));

const originalMusic = music.filter((m) => (m.data.category || '原创音乐') === '原创音乐');
const remixMusic = music.filter((m) => m.data.category === '混音');
---

<BaseLayout title="音乐作品" description="Nathuris 的音乐作品集">

  <section class="py-16">
    <div class="container-main">
      <h1 class="section-title mb-12">🎧 音乐作品</h1>

      <!-- ========== 原创音乐 ========== -->
      <section class="mb-16">
        <div class="mb-6">
          <h2 class="text-2xl font-bold">🎼 原创音乐</h2>
          <p class="mt-1 text-slate-500 dark:text-slate-400">我的原创音乐</p>
        </div>
        {
          originalMusic.length > 0 ? (
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {originalMusic.map((item) => (
                <MusicCard
                  title={item.data.title}
                  description={item.data.description}
                  coverImage={item.data.coverImage}
                  linkUrl={item.data.linkUrl}
                  tags={item.data.tags}
                  date={item.data.date}
                  slug={item.id}
                />
              ))}
            </div>
          ) : (
            <p class="py-12 text-center text-sm text-slate-400 dark:text-slate-500">还没有原创音乐作品</p>
          )
        }
      </section>

      <!-- ========== 混音 ========== -->
      <section>
        <div class="mb-6">
          <h2 class="text-2xl font-bold">🎚️ 混音</h2>
          <p class="mt-1 text-slate-500 dark:text-slate-400">我的混音歌单</p>
        </div>
        {
          remixMusic.length > 0 ? (
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {remixMusic.map((item) => (
                <MusicCard
                  title={item.data.title}
                  description={item.data.description}
                  coverImage={item.data.coverImage}
                  linkUrl={item.data.linkUrl}
                  tags={item.data.tags}
                  date={item.data.date}
                  slug={item.id}
                />
              ))}
            </div>
          ) : (
            <p class="py-12 text-center text-sm text-slate-400 dark:text-slate-500">还没有混音作品</p>
          )
        }
      </section>
    </div>
  </section>
</BaseLayout>
