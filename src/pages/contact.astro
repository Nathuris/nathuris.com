---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="联系" description="联系 Nathuris">

  <section class="py-16">
    <div class="container-main">
      <div class="mx-auto max-w-2xl">
        <h1 class="section-title text-center">📬 联系我</h1>
        <p class="mt-4 text-center text-slate-500 dark:text-slate-400">
          如果你对我的音乐或项目感兴趣，欢迎联系
        </p>

        <div class="mt-12 grid gap-6 sm:grid-cols-2">
          <!-- 邮箱 -->
          <a href="mailto:hi@nathuris.com" class="card flex flex-col items-center text-center no-underline hover:border-accent-200 dark:hover:border-accent-800">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent-100 dark:bg-accent-950">
              <svg class="h-6 w-6 text-accent-600 dark:text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-slate-900 dark:text-white">电子邮件</h3>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">hi@nathuris.com</p>
          </a>

          <!-- GitHub -->
          <a href="https://github.com/Nathuris" target="_blank" rel="noopener noreferrer" class="card flex flex-col items-center text-center no-underline hover:border-accent-200 dark:hover:border-accent-800">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent-100 dark:bg-accent-950">
              <svg class="h-6 w-6 text-accent-600 dark:text-accent-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-slate-900 dark:text-white">GitHub</h3>
            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">@Nathuris</p>
          </a>
        </div>

        <!-- 其他社交链接 -->
        <div class="mt-16 text-center">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-white">其他平台</h3>
          <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
            SoundCloud、Bilibili、小红书等平台的链接也在这里（后续可以随时在后台添加）
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
