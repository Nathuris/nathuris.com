---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const settings = await getCollection('settings');
const site = settings[0]?.data;
---

<BaseLayout title="联系" description="联系 Nathuris">

  <section class="py-16">
    <div class="container-main">
      <div class="mx-auto max-w-2xl">
        <h1 class="section-title text-center">📬 联系我</h1>
        <p class="mt-4 text-center text-slate-500 dark:text-slate-400">
          如果你对我的音乐或项目感兴趣，欢迎联系
        </p>

        <div class="mt-12 grid gap-6 sm:grid-cols-2">
          <!-- 邮箱 -->
          {site?.email && (
            <a href={`mailto:${site.email}`} class="card flex flex-col items-center text-center no-underline hover:border-accent-200 dark:hover:border-accent-800">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent-100 dark:bg-accent-950">
                <svg class="h-6 w-6 text-accent-600 dark:text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <h3 class="font-semibold text-slate-900 dark:text-white">电子邮件</h3>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{site.email}</p>
            </a>
          )}

          <!-- GitHub -->
          {site?.github && (
            <a href={site.github} target="_blank" rel="noopener noreferrer" class="card flex flex-col items-center text-center no-underline hover:border-accent-200 dark:hover:border-accent-800">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent-100 dark:bg-accent-950">
                <svg class="h-6 w-6 text-accent-600 dark:text-accent-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
              </div>
              <h3 class="font-semibold text-slate-900 dark:text-white">GitHub</h3>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{site.github.replace('https://github.com/', '@')}</p>
            </a>
          )}

          <!-- 网易云音乐 -->
          {site?.neteaseMusic && (
            <a href={site.neteaseMusic} target="_blank" rel="noopener noreferrer" class="card flex flex-col items-center text-center no-underline hover:border-accent-200 dark:hover:border-accent-800">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent-100 dark:bg-accent-950">
                <svg class="h-6 w-6 text-accent-600 dark:text-accent-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
                </svg>
              </div>
              <h3 class="font-semibold text-slate-900 dark:text-white">网易云音乐</h3>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">在网易云关注我</p>
            </a>
          )}

          <!-- 抖音 -->
          {site?.douyin && (
            <a href={site.douyin} target="_blank" rel="noopener noreferrer" class="card flex flex-col items-center text-center no-underline hover:border-accent-200 dark:hover:border-accent-800">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent-100 dark:bg-accent-950">
                <svg class="h-6 w-6 text-accent-600 dark:text-accent-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                </svg>
              </div>
              <h3 class="font-semibold text-slate-900 dark:text-white">抖音</h3>
              <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">在抖音关注我</p>
            </a>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
