---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => {
  const orderA = a.data.order ?? 0;
  const orderB = b.data.order ?? 0;
  if (orderB !== orderA) return orderB - orderA;
  return (b.data.date?.getTime() || 0) - (a.data.date?.getTime() || 0);
});

const allTags = [...new Set(projects.flatMap((p) => p.data.tags || []))].sort();
---

<BaseLayout title="项目作品" description="Nathuris 的 Vibe Coding 项目成果">

  <section class="py-16">
    <div class="container-main">
      <div class="mb-8">
        <h1 class="section-title">💻 项目作品</h1>
        <p class="mt-2 text-slate-500 dark:text-slate-400">
          我的开发成果
        </p>
      </div>

      <!-- 标签筛选 -->
      {
        allTags.length > 0 && (
          <div class="mb-8 flex flex-wrap gap-2">
            <button class="tag cursor-pointer bg-accent-100 text-accent-700 dark:bg-accent-950 dark:text-accent-400 tag-filter active" data-tag="all">
              全部
            </button>
            {allTags.map((tag) => (
              <button class="tag cursor-pointer hover:bg-slate-200 dark:hover:bg-slate-700 tag-filter" data-tag={tag}>
                {tag}
              </button>
            ))}
          </div>
        )
      }

      {
        projects.length > 0 ? (
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4" id="project-grid">
            {projects.map((item) => (
              <div class="project-item" data-tags={JSON.stringify(item.data.tags || [])}>
                <ProjectCard
                  title={item.data.title}
                  description={item.data.description}
                  image={item.data.image}
                  tags={item.data.tags}
                  sourceUrl={item.data.sourceUrl}
                  slug={item.id}
                />
              </div>
            ))}
          </div>
        ) : (
          <div class="py-20 text-center">
            <p class="text-slate-400 dark:text-slate-500">还没有项目作品，敬请期待 💻</p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.tag-filter')?.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = (btn as HTMLElement).dataset.tag;
      document.querySelectorAll('.tag-filter').forEach((b) => {
        b.classList.remove('bg-accent-100', 'text-accent-700', 'dark:bg-accent-950', 'dark:text-accent-400', 'active');
      });
      btn.classList.add('bg-accent-100', 'text-accent-700', 'dark:bg-accent-950', 'dark:text-accent-400', 'active');

      document.querySelectorAll('.project-item').forEach((item) => {
        const el = item as HTMLElement;
        const tags: string[] = JSON.parse(el.dataset.tags || '[]');
        if (tag === 'all' || tags.includes(tag || '')) {
          el.classList.remove('hidden');
        } else {
          el.classList.add('hidden');
        }
      });
    });
  });
</script>
